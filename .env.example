# ===========================================
# 环境变量示例文件 (Environment Variables Example)
# ===========================================
# 用法：复制此文件为 .env.local 进行本地开发覆盖（.env.local 不会被提交到 git）
#   cp .env.example .env.local
#
# 注意：所有自定义环境变量必须以 VITE_ 开头，否则无法在客户端代码中访问

# API 基础地址（后端服务地址，必须使用 https://）
VITE_API_BASE_URL=https://big-event-vue-api-t.itheima.net

# 应用部署基础路径（默认根路径，部署到子路径时改为如 '/admin/'）
VITE_BASE_PATH=/
