# ===========================================
# 开发环境配置 (Development Environment)
# ===========================================
# 作用：执行 `pnpm dev` 时加载此文件
# 说明：开发环境直接访问公开 API（存在跨域，由 Vite dev server 代理或浏览器 CORS 处理）

# API 基础地址（本地 Mock Server）
# 先启动 `pnpm mock` 再 `pnpm dev`；或直接 `pnpm dev:mock` 一键启动
VITE_API_BASE_URL=http://localhost:3000

# 应用部署基础路径（默认根路径，部署到子路径时改为如 '/admin/'）
VITE_BASE_PATH=/
