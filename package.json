  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mock": "node mock/server.mjs",
    "dev:mock": "concurrently \"pnpm mock\" \"pnpm dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
